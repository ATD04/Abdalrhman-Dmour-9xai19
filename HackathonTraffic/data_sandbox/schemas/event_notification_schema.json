{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Incident Event Notification Schema",
  "description": "Contractual format for structured incident alerts generated by the Phase 2 detection module. Storage-ready for Phase 3 event logging layer.",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "description": "Unique event identifier (e.g., EVT-2026-04-21-001)" },
    "timestamp": { "type": "string", "format": "date-time" },
    "site_id": { "type": "string" },
    "camera_id": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": ["stalled_vehicle", "queue_spillback", "abnormal_stopping", "unexpected_trajectory", "congestion_buildup"]
    },
    "zone_id": { "type": "string", "description": "Must match roi_masks.json" },
    "approach": { "type": "string", "enum": ["North", "South", "East", "West"] },
    "lane_id": { "type": "string" },
    "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "estimated_queue_length_m": { "type": "number", "minimum": 0 },
    "snapshot_path": { "type": "string" },
    "clip_ref": { "type": "string" },
    "notes": { "type": "string" }
  },
  "required": ["event_id", "timestamp", "site_id", "event_type", "severity", "confidence_score"]
}
