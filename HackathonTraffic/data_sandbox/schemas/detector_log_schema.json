{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Detector Level Log Schema",
  "type": "object",
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "detector_id": { "type": "string" },
    "vehicle_count": { "type": "integer", "minimum": 0 },
    "occupancy": { "type": "number", "minimum": 0, "maximum": 100 },
    "speed_avg": { "type": "number", "minimum": 0 }
  },
  "required": ["timestamp", "detector_id", "vehicle_count"]
}
