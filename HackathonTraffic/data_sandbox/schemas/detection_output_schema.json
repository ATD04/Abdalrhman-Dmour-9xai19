{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vehicle Detection Output Schema",
  "description": "Contractual output format from the Phase 2 real-time detection node. All detection modules must produce objects conforming to this schema.",
  "type": "object",
  "properties": {
    "frame_id": { "type": "string", "description": "Unique frame identifier (e.g., frame_000150)" },
    "timestamp": { "type": "string", "format": "date-time" },
    "camera_id": { "type": "string", "description": "Must match camera_registry.json" },
    "detections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "track_id": { "type": "integer" },
          "class": { "type": "string", "enum": ["car", "bus", "truck", "motorcycle", "van"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "bbox_xyxy": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
          "bbox_normalized": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
          "speed_kmh": { "type": "number", "minimum": 0 },
          "lane_id": { "type": "string", "description": "Must match lane_map.json" }
        },
        "required": ["track_id", "class", "confidence", "bbox_normalized"]
      }
    }
  },
  "required": ["frame_id", "timestamp", "camera_id", "detections"]
}
