# Ignore heavy datasets in the sandbox to prevent enormous git commits
HackathonTraffic/data_sandbox/video/*
!HackathonTraffic/data_sandbox/video/.gitkeep
HackathonTraffic/data_sandbox/detector/*
!HackathonTraffic/data_sandbox/detector/.gitkeep
HackathonTraffic/data_sandbox/signals/*
!HackathonTraffic/data_sandbox/signals/.gitkeep
HackathonTraffic/data_sandbox/annotations/*
!HackathonTraffic/data_sandbox/annotations/.gitkeep
HackathonTraffic/backend/ai/weights/

# Ignore sensitive database/broker configs locally
HackathonTraffic/.env
HackathonTraffic/infrastructure/kafka/data/
HackathonTraffic/infrastructure/monitoring/data/

