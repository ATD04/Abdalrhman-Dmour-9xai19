# ─── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ─── Sibling Services ────────────────────────────────────────────────────────
AGENT_SERVICE_URL=http://localhost:8200
KNOWLEDGE_SERVICE_URL=http://localhost:8100

# ─── Guardrail Settings ──────────────────────────────────────────────────────
INPUT_GUARDRAIL_ENABLED=true
OUTPUT_GUARDRAIL_ENABLED=true

# ─── Audit Settings ──────────────────────────────────────────────────────────
AUDIT_RETENTION_DAYS=90

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8300
