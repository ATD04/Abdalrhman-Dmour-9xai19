# ─── Knowledge Service Environment Template ──────────────────────────────────
# Copy this to .env and fill in your values.
# DO NOT commit .env to version control!

GEMINI_API_KEY=your-gemini-api-key-here

# ─── Embedding Config ───────────────────────────────────────────────────────
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIMENSIONS=768

# ─── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8100

# ─── Ingestion ──────────────────────────────────────────────────────────────
PDF_DPI=200
EXTRACT_PDF_TEXT=false
ENABLE_LLM_PDF_TEXT_EXTRACTION=true
PDF_TEXT_EXTRACTION_MODEL=gemini-2.5-flash
PDF_TEXT_EXTRACTION_MAX_RETRIES=2
MAX_UPLOAD_SIZE_MB=100
DEFAULT_CHUNK_STRATEGY=page

# ─── Retrieval ──────────────────────────────────────────────────────────────
DEFAULT_TOP_K=5
DEFAULT_MIN_SCORE=0.0
